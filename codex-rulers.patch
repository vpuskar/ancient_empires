+
+function getEra(year: number): Era {
+  if (year < -509) return { name: "Roman Kingdom", color: "#6B6560" };
+  if (year < -27) return { name: "Roman Republic", color: "#C9A84C" };
+  if (year < 96) return { name: "Early Empire", color: "#8B0000" };
+  if (year < 192) return { name: "Pax Romana", color: "#5DCAA5" };
+  if (year < 284) return { name: "Crisis of the Third Century", color: "#E24B4A" };
+  if (year < 395) return { name: "Dominate", color: "#AFA9EC" };
+  return { name: "Fall of the West", color: "#6B6560" };
+}
+
+function formatYear(y: number): string {
+  if (y < 0) return `${Math.abs(y)} BC`;
+  return `${y} AD`;
+}
+
+function reignLength(r: Ruler): number {
+  return Math.abs((r.reign_end || 0) - r.reign_start);
+}
+
+function deathIcon(cause: string): DeathIconInfo {
+  switch (cause) {
+    case "assassination": return { symbol: "\u2020", color: "#E24B4A", label: "Assassination" };
+    case "battle": return { symbol: "\u2694\uFE0F", color: "#E24B4A", label: "Killed in battle" };
+    case "suicide": return { symbol: "\u2666", color: "#E8C547", label: "Suicide" };
+    case "natural": return { symbol: "\u25CF", color: "#5DCAA5", label: "Natural causes" };
+    default: return { symbol: "?", color: "rgba(240,236,226,0.3)", label: "Unknown" };
   }
+}
